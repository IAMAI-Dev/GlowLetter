page {
  height: 100%;
  overflow: hidden;
  background: #f8f5eb;
}

.main-shell,
.main-scroll {
  width: 100%;
  height: 100vh;
  background: #f8f5eb;
}

.main-shell {
  position: relative;
  overflow: hidden;
}

.main-scroll.is-active {
  animation: main-view-enter 160ms cubic-bezier(0.2, 0.75, 0.25, 1) both;
}

@keyframes main-view-enter {
  from {
    opacity: 0.72;
    transform: translateY(6rpx);
  }

  to {
    opacity: 1;
    transform: none;
  }
}

.home-page {
  padding-top: 0;
}

.home-hero {
  min-height: 0;
}

.home-eyebrow {
  display: block;
  margin-top: 56rpx;
}

.home-title,
.home-lead,
.hero-meta,
.section-title-desc {
  display: block;
}

.home-title {
  max-width: 620rpx;
}

.home-button-group {
  margin-top: 0;
}

.button-arrow {
  font-size: 40rpx;
  font-weight: 400;
  line-height: 1;
}

.quick-symbol {
  width: 48rpx;
  height: 48rpx;
  color: #576459;
}

.quick-symbol-info {
  border: 3rpx solid currentColor;
  border-radius: 50%;
  font-family: serif;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
}

.quick-symbol-profile {
  position: relative;
}

.quick-profile-head {
  position: absolute;
  top: 0;
  left: 15rpx;
  width: 18rpx;
  height: 18rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.quick-profile-body {
  position: absolute;
  right: 4rpx;
  bottom: 0;
  left: 4rpx;
  height: 22rpx;
  border: 3rpx solid currentColor;
  border-bottom: 0;
  border-radius: 24rpx 24rpx 0 0;
}

.history-page,
.profile-page {
  padding-top: 8rpx;
}

.history-summary-row {
  align-items: flex-end;
}

.history-title,
.history-lead,
.record-time,
.record-name,
.record-reading,
.empty-title,
.empty-desc,
.profile-name,
.count-label,
.count-number {
  display: block;
}

.history-lead {
  font-size: 30rpx;
}

.record-name {
  margin-top: 8rpx;
}

.empty-clock {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  margin: 0 auto 32rpx;
  border: 3rpx solid #576459;
  border-radius: 50%;
}

.empty-clock-hour,
.empty-clock-minute {
  position: absolute;
  top: 39rpx;
  left: 39rpx;
  height: 3rpx;
  border-radius: 3rpx;
  background: #576459;
  transform-origin: left center;
}

.empty-clock-hour {
  width: 19rpx;
  transform: rotate(-90deg);
}

.empty-clock-minute {
  width: 23rpx;
  transform: rotate(28deg);
}

.empty-desc {
  margin-top: 16rpx;
}

.empty-action {
  display: inline-flex;
  margin-top: 40rpx;
}

.load-more {
  margin-top: 28rpx;
}

.history-error-notice {
  margin-top: 28rpx;
}

.profile-status {
  margin-top: 14rpx;
}

.count-number {
  margin-top: 24rpx;
  font-size: 96rpx;
}

.menu-arrow {
  color: #576459;
  font-size: 44rpx;
  font-weight: 300;
  line-height: 1;
}
