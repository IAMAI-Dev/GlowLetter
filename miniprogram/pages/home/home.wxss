.home-page {
  padding-top: 0;
}

.home-hero {
  min-height: 0;
}

.home-eyebrow {
  display: block;
  margin-top: 56rpx;
}

.home-title,
.home-lead,
.hero-meta,
.section-title-desc {
  display: block;
}

.home-title {
  max-width: 620rpx;
}

.home-button-group {
  margin-top: 0;
}

.button-arrow {
  font-size: 40rpx;
  font-weight: 400;
  line-height: 1;
}

.quick-symbol {
  width: 48rpx;
  height: 48rpx;
  color: #576459;
}

.quick-symbol-info {
  border: 3rpx solid currentColor;
  border-radius: 50%;
  font-family: serif;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
}

.quick-symbol-profile {
  position: relative;
}

.quick-profile-head {
  position: absolute;
  top: 0;
  left: 15rpx;
  width: 18rpx;
  height: 18rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.quick-profile-body {
  position: absolute;
  right: 4rpx;
  bottom: 0;
  left: 4rpx;
  height: 22rpx;
  border: 3rpx solid currentColor;
  border-bottom: 0;
  border-radius: 24rpx 24rpx 0 0;
}
