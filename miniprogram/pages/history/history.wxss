.history-page {
  padding-top: 8rpx;
}

.history-summary-row {
  align-items: flex-end;
}

.history-title,
.history-lead,
.record-time,
.record-name,
.record-reading,
.empty-title,
.empty-desc {
  display: block;
}

.history-lead {
  font-size: 30rpx;
}

.record-name {
  margin-top: 8rpx;
}

.empty-clock {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  margin: 0 auto 32rpx;
  border: 3rpx solid #576459;
  border-radius: 50%;
}

.empty-clock-hour,
.empty-clock-minute {
  position: absolute;
  top: 39rpx;
  left: 39rpx;
  height: 3rpx;
  border-radius: 3rpx;
  background: #576459;
  transform-origin: left center;
}

.empty-clock-hour {
  width: 19rpx;
  transform: rotate(-90deg);
}

.empty-clock-minute {
  width: 23rpx;
  transform: rotate(28deg);
}

.empty-desc {
  margin-top: 16rpx;
}

.empty-action {
  display: inline-flex;
  margin-top: 40rpx;
}

.load-more {
  margin-top: 28rpx;
}
