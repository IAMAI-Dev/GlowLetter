<custom-navbar
  title="历史记录"
  back-route="/pages/home/home"
  action="refresh"
  action-label="刷新历史记录"
  bind:action="handleNavbarAction"
/>

<view class="page tab-page history-page">
  <view>
    <text class="eyebrow">仅显示当前访客的数据</text>
    <view class="row-between history-summary-row">
      <view class="grow">
        <text class="heading-2 history-title">检测留痕</text>
        <text class="lead history-lead">按时间倒序查看已保存的演示记录。</text>
      </view>
      <text class="meta"><text class="num">{{total}}</text> 条</text>
    </view>
  </view>

  <view class="section">
    <view wx:if="{{records.length}}" class="record-list">
      <view
        wx:for="{{records}}"
        wx:key="id"
        class="record-card"
        data-id="{{item.id}}"
        role="button"
        aria-label="查看样品 {{item.sampleName}} 的记录"
        bindtap="openDetail"
      >
        <view class="row-between">
          <view>
            <text class="meta record-time">{{item.timeLabel}}</text>
            <text class="heading-3 record-name">{{item.sampleName}}</text>
          </view>
          <text class="tag">演示数据</text>
        </view>
        <text class="record-reading">{{item.result.concentration}}<text class="record-unit"> {{item.result.unit}}</text></text>
        <view class="record-tags">
          <text class="tag">{{item.result.gradeCode}} 级 · {{item.result.gradeLabel}}</text>
          <text class="tag">{{item.result.rangeLabel}}</text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <view class="empty-clock" aria-hidden="true">
        <view class="empty-clock-hour"></view>
        <view class="empty-clock-minute"></view>
      </view>
      <text class="heading-3 empty-title">还没有保存记录</text>
      <text class="muted empty-desc">完成一次演示检测并保存，记录会出现在这里。</text>
      <button class="btn btn-primary empty-action" bindtap="startDetection">开始第一次检测</button>
    </view>

    <button wx:if="{{hasMore}}" class="btn btn-secondary btn-block load-more" bindtap="loadMore">加载更多记录</button>
  </view>

  <view class="section section-bordered">
    <view class="notice">正式版本将通过云函数校验用户身份，普通用户只能读取和删除自己的记录。</view>
  </view>
</view>

<custom-tabbar active="history" />
