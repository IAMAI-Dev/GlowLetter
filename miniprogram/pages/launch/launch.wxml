<view class="launch page-enter">
  <view class="brand-mark brand-mark-logo launch-logo" aria-hidden="true">
    <image class="brand-image" src="/assets/images/team-logo.png" mode="aspectFit" />
  </view>
  <text class="eyebrow launch-eyebrow">iGEM · 原型演示版</text>
  <text class="heading-1 launch-title">绿荧来信</text>
  <text class="lead launch-lead">正在初始化云环境与访客身份，不需要注册账号或填写密码。</text>
  <view class="launch-status" aria-live="polite">
    <view class="status-dot"></view>
    <text>{{statusText}}</text>
  </view>
  <view wx:if="{{hasError}}" class="button-group launch-actions">
    <button class="btn btn-primary btn-block" disabled="{{initializing}}" bindtap="handleRetry">重新尝试</button>
    <button class="btn btn-secondary btn-block" bindtap="enterDemo">以演示身份进入</button>
  </view>
</view>

<route-transition active="{{routeTransitioning}}" tone="{{routeTransitionTone || 'light'}}" />
