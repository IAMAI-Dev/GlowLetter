:host {
  display: block;
  width: 0;
  height: 0;
}

.route-transition {
  position: fixed;
  z-index: 1000;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  overflow: hidden;
  background: #f8f5eb;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 110ms ease-out, visibility 0s linear 110ms;
}

.route-transition-dark {
  background: #07120c;
}

.route-transition.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transition: opacity 110ms ease-out;
}

.route-transition-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 72vw;
  height: 72vw;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(78, 231, 95, 0.16) 0%, rgba(78, 231, 95, 0) 68%);
  opacity: 0;
  transform: translate(-50%, -50%) scale(0.72);
  transition: opacity 140ms ease-out, transform 180ms cubic-bezier(0.2, 0.75, 0.25, 1);
}

.route-transition.is-active .route-transition-glow {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.route-transition-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #4ee75f;
  box-shadow: 0 0 0 12rpx rgba(78, 231, 95, 0.08), 0 0 36rpx rgba(78, 231, 95, 0.34);
  opacity: 0;
  transform: translate(-50%, -50%) scale(0.72);
}

.route-transition.is-active .route-transition-pulse {
  animation: route-pulse 480ms ease-in-out infinite alternate;
}

@keyframes route-pulse {
  from {
    opacity: 0.48;
    transform: translate(-50%, -50%) scale(0.78);
  }

  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.24);
  }
}
